   "source": [
    "# Load raw data\n",
    "try:\n",
    "    df = pd.read_csv('raw_bank_reviews.csv')\n",
    "except FileNotFoundError:\n",
    "    print(\"Error: raw_bank_reviews.csv not found. Run scraper.py first.\")\n",
    "    exit()"
   ]
  },
  {
   "cell_type": "code",
