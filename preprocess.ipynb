   "source": [
    "# Preprocessing steps for Task 1\n",
    "# Remove duplicates\n",
    "df.drop_duplicates(subset=['review', 'date', 'bank'], inplace=True)\n",
    "print(f\"Removed duplicates, {len(df)} reviews remain\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "c42acfee",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "After handling missing ratings, 1182 reviews remain\n"
     ]
    }
   ],
   "source": [
    "# Handle missing data\n",
    "df['review'] = df['review'].fillna('N/A')\n",
    "df['date'] = df['date'].fillna('N/A')\n",
    "df = df.dropna(subset=['rating'])  # Drop rows with missing ratings\n",
    "print(f\"After handling missing ratings, {len(df)} reviews remain\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "9e54532b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Normalized dates to YYYY-MM-DD format\n"
     ]
    }
   ],
   "source": [
    "# Normalize date formats\n",
    "df['date'] = pd.to_datetime(df['date'], errors='coerce')\n",
    "df['date'] = df['date'].apply(lambda x: x.strftime('%Y-%m-%d') if pd.notnull(x) else 'N/A')\n",
    "print(\"Normalized dates to YYYY-MM-DD format\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "6df6d0c6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Validate and normalize data\n",
    "df['rating'] = df['rating'].astype(int)\n",
    "df = df[df['rating'].between(1, 5)]\n",
    "df['source'] = 'Google Play'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "c3cc0833",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Preprocessing for Task 2: NLP preprocessing\n",
    "import spacy\n",
    "nlp = spacy.load('en_core_web_sm')\n",
    "\n",
    "def preprocess_text(text):\n",
    "    if not isinstance(text, str):\n",
    "        return \"\"\n",
    "    doc = nlp(text.lower())\n",
    "    tokens = [token.lemma_ for token in doc if not token.is_stop and token.is_alpha]\n",
    "    return \" \".join(tokens)\n",
    "\n",
    "df['processed_review'] = df['review'].apply(preprocess_text)"
   ]
  },
